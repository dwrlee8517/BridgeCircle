{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "doppler",
      "runtimeArgs": ["run", "-p", "bridgecircle", "-c", "dev", "--", "sh", "-c", "pnpm --dir app install && pnpm --dir app dev"],
      "port": 3000
    },
    {
      "name": "next-dev-preview",
      "cwd": "app",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "pnpm exec next dev --port $PORT"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
