{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "doppler",
      "runtimeArgs": ["run", "-p", "bridgecircle", "-c", "dev_personal", "--", "sh", "-c", "pnpm --dir app install && pnpm --dir app dev"],
      "port": 3001
    },
    {
      "name": "next-dev-preview",
      "cwd": "app",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "pnpm exec next dev --port $PORT"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "static-docs",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "python3 -m http.server $PORT"],
      "port": 8137,
      "autoPort": true
    }
  ]
}
