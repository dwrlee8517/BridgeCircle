{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/db/database.types.ts",
    "src/db/repositories/avatar-storage.ts",
    "src/db/repositories/connections*.ts",
    "src/db/repositories/conversations*.ts",
    "src/db/repositories/help*.ts",
    "src/db/repositories/home*.ts",
    "src/db/repositories/member-context*.ts",
    "src/db/repositories/messages*.ts",
    "src/db/repositories/school*.ts",
    "src/lib/connections/**/*.ts",
    "src/lib/conversations/**/*.ts",
    "src/lib/help/**/*.ts",
    "src/lib/home/**/*.ts",
    "src/lib/messages/**/*.ts",
    "src/lib/school/**/*.ts",
    "src/app/_lib/**/*.ts",
    "src/app/(member)/page.tsx",
    "src/app/(member)/home-*.tsx",
    "src/app/(member)/help/page.tsx",
    "src/app/(member)/help/help-get-home.tsx",
    "src/app/(member)/help/help-question-form.tsx",
    "src/app/(member)/help/help-draft-storage*.ts",
    "src/app/(member)/messages/use-waiting-preference.ts",
    "src/app/(member)/messages/[id]/**/*.tsx",
    "src/app/api/help/asks/[askId]/outcome-share/route.ts"
  ],
  "exclude": ["node_modules", ".next", "tests/e2e"]
}
