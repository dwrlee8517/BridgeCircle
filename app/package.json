{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "NODE_ENV=development next dev -p 3000",
    "dev:local": "doppler run -p bridgecircle -c dev_local -- next dev -p 3000",
    "dev:local:live": "doppler run -p bridgecircle -c dev_local_live -- next dev -p 3000",
    "build": "NODE_ENV=production next build",
    "start": "NODE_ENV=production next start",
    "lint": "eslint",
    "typecheck:v2-foundation": "tsc --noEmit -p tsconfig.v2-foundation.json --pretty false",
    "check:supabase-boundaries": "bash scripts/check-supabase-boundaries.sh",
    "test:db:concurrency": "bash scripts/test-foundation-concurrency.sh",
    "check:tokens": "bash scripts/check-design-tokens.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:start": "bash scripts/db-start.sh",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db --local",
    "db:types:local": "supabase gen types typescript --local --schema public,api > src/db/database.types.ts && perl -0pi -e 's/\\n+\\z/\\n/' src/db/database.types.ts",
    "db:types": "supabase gen types typescript --linked --schema public,api > src/db/database.types.ts && perl -0pi -e 's/\\n+\\z/\\n/' src/db/database.types.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.73.1",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
