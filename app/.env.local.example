# Copy to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
# Optional override for the From address; defaults are wired in src/notify/resend.ts
# RESEND_FROM=BridgeCircle <invites@bridgecircle.org>

# --- LLM (Anthropic) — used for resume extraction and NL search ---
ANTHROPIC_API_KEY=

# --- Error tracking ---
SENTRY_AUTH_TOKEN=

# --- App URLs (used in email links) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Profile enrichment providers ---
# See docs/architecture/profile-enrichment.md for the full provider plan.
#
# Defaults route onboarding+manual to LinkdAPI and the monthly sweep to
# Bright Data, with PDL as the cross-job fallback. Set these only when the
# default routing needs to change (e.g. LinkdAPI shutdown → flip primaries
# to pdl):
#   ENRICHMENT_PRIMARY_ONBOARDING=pdl
#   ENRICHMENT_PRIMARY_MANUAL=pdl
#   ENRICHMENT_PRIMARY_SWEEP=linkdapi
LINKDAPI_API_KEY=
BRIGHTDATA_API_KEY=
PDL_API_KEY=
