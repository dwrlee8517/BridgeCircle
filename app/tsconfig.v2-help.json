{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/db/database.types.ts",
    "src/db/repositories/help*.ts",
    "src/db/realtime/help*.ts",
    "src/lib/help/**/*.ts",
    "src/lib/outbox/**/*.ts",
    "src/integrations/ai/help*.ts",
    "src/workers/outbox/**/*.ts",
    "src/app/(member)/help/page.tsx",
    "src/app/(member)/help/help-get-home.tsx",
    "src/app/(member)/help/help-give-home.tsx",
    "src/app/(member)/help/help-preferences-actions.ts",
    "src/app/(member)/help/help-preferences-form.tsx",
    "src/app/(member)/help/help-question-form.tsx",
    "src/app/(member)/help/help-draft-storage*.ts",
    "src/app/(member)/help/help-assistance-client.ts",
    "src/app/(member)/help/recent-ask-list.tsx",
    "src/app/(member)/help/ask/**/*.tsx",
    "src/app/(member)/help/ask-circle/**/*",
    "src/app/(member)/help/asks/**/*",
    "src/app/api/help/**/*.ts"
